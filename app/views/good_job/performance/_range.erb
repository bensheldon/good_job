<% range_badge_label = performance_range.key || t(".custom_range") %>
<% reload_range_label = t(".reload_range") %>
<% reload_range_query = range_context.merge(performance_range.reload_params).to_query %>
<% reload_range_path = reload_range_query.present? ? "#{range_path}?#{reload_range_query}" : range_path %>
<% custom_range_path = "#{range_path}?#{range_context.merge(performance_range.custom_params).to_query}" %>
<% time_zone_label = Time.zone.name %>
<% range_form_data = {
  action: "submit->performance-range#prepareSubmission",
  controller: "performance-range",
  performance_range_application_time_zone_value: time_zone_label,
  performance_range_application_time_zone_identifier_value: Time.zone.tzinfo.name,
  performance_range_end_fallback_value: performance_range.end_local_value,
  performance_range_end_label_value: performance_range.end_label,
  performance_range_end_timestamp_value: performance_range.canonical_timestamp(performance_range.end_time),
  performance_range_label_style_value: performance_range.label_style,
  performance_range_maximum_value: GoodJob::PerformanceRange::MAXIMUM_LOCAL_VALUE,
  performance_range_minimum_value: GoodJob::PerformanceRange::MINIMUM_LOCAL_VALUE,
  performance_range_start_fallback_value: performance_range.start_local_value,
  performance_range_start_label_value: performance_range.start_label,
  performance_range_start_timestamp_value: performance_range.canonical_timestamp(performance_range.start_time),
} %>

<%= tag.form(
      action: range_path,
      method: "get",
      class: "performance-range-toolbar mb-3",
      aria: { describedby: "performance-range-time-zone", labelledby: "performance-range-name" },
      data: range_form_data
    ) do %>
  <span class="visually-hidden" id="performance-range-name"><%= t ".time_range" %></span>
  <% if range_context["locale"] %>
    <%= hidden_field_tag "locale", range_context["locale"] %>
  <% end %>
  <%= hidden_field_tag "chart_start", performance_range.canonical_timestamp(performance_range.start_time), disabled: true, id: nil, data: { performance_range_target: "startCanonicalInput" } %>
  <%= hidden_field_tag "chart_end", performance_range.canonical_timestamp(performance_range.end_time), disabled: true, id: nil, data: { performance_range_target: "endCanonicalInput" } %>
  <%= hidden_field_tag GoodJob::PerformanceRange::TIME_ZONE_PARAMETER_KEY, nil, disabled: true, id: nil, data: { performance_range_target: "timeZoneInput" } %>
  <div class="performance-range-control">
    <label class="performance-range-state performance-range-date" title="<%= t ".start_time" %>">
      <%= render_icon "clock", class: "me-1" %>
      <span data-performance-range-target="startLabel"><%= performance_range.start_label %></span>
      <%= datetime_local_field_tag "chart_start", performance_range.start_local_value, min: GoodJob::PerformanceRange::MINIMUM_LOCAL_VALUE, max: GoodJob::PerformanceRange::MAXIMUM_LOCAL_VALUE, step: 1, required: true, class: "performance-range-native-input", aria: { describedby: "performance-range-time-zone", label: t(".start_time") }, data: { performance_range_target: "startInput", action: "input->performance-range#edit input->performance-range#constrain change->performance-range#constrain change->performance-range#submitRange click->performance-range#openPicker" } %>
    </label>
    <label class="performance-range-state performance-range-date" title="<%= t ".end_time" %>">
      <span data-performance-range-target="endLabel"><%= performance_range.end_label %></span>
      <%= datetime_local_field_tag "chart_end", performance_range.end_local_value, min: GoodJob::PerformanceRange::MINIMUM_LOCAL_VALUE, max: GoodJob::PerformanceRange::MAXIMUM_LOCAL_VALUE, step: 1, required: true, class: "performance-range-native-input", aria: { describedby: "performance-range-time-zone", label: t(".end_time") }, data: { performance_range_target: "endInput", action: "input->performance-range#edit input->performance-range#constrain change->performance-range#constrain change->performance-range#submitRange click->performance-range#openPicker" } %>
    </label>
    <div class="performance-range-selector d-inline-flex position-relative">
      <span class="performance-range-state performance-range-key rounded-end-0">
        <%= range_badge_label %>
      </span>
      <button class="btn btn-outline-secondary dropdown-toggle dropdown-toggle-split performance-range-toggle rounded-start-0" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="<%= t ".open_time_ranges" %>">
        <span class="visually-hidden"><%= t ".open_time_ranges" %></span>
      </button>
      <ul class="dropdown-menu dropdown-menu-end performance-range-menu">
        <li><h6 class="dropdown-header"><%= t ".quick_ranges" %></h6></li>
        <% performance_range.options.each do |range| %>
          <% active = performance_range.key == range[:key] %>
          <% preset_range_path = "#{range_path}?#{range_context.merge('chart_range' => range[:key]).to_query}" %>
          <li>
            <%= link_to preset_range_path, class: ["dropdown-item", "performance-range-menu-item", "d-flex", "align-items-center", "gap-2", ("active" if active)], aria: { current: ("page" if active) } do %>
              <span class="performance-range-option-key"><%= range[:label] %></span>
              <span class="flex-grow-1"><%= t ".range_options.#{range[:key]}" %></span>
            <% end %>
          </li>
        <% end %>
        <li><hr class="dropdown-divider"></li>
        <li>
          <%= link_to custom_range_path, class: ["dropdown-item", "performance-range-menu-item", "d-flex", "align-items-center", "gap-2", "performance-range-custom", ("active" if performance_range.custom?)], aria: { current: ("page" if performance_range.custom?) } do %>
            <span class="performance-range-option-key">#</span>
            <span class="flex-grow-1"><%= t ".custom_range" %></span>
            <% if local_assigns[:drag_enabled] %>
              <small class="text-body-secondary text-nowrap"><%= t ".custom_range_hint" %></small>
            <% end %>
          <% end %>
        </li>
      </ul>
    </div>
    <%= link_to reload_range_path, class: %w[btn btn-outline-secondary performance-range-reload flex-shrink-0], aria: { label: reload_range_label }, data: { turbo: false }, title: reload_range_label do %>
      <%= render_icon "arrow_clockwise" %>
      <span class="visually-hidden"><%= reload_range_label %></span>
    <% end %>
  </div>
  <div class="performance-range-meta small text-body-secondary mt-2" id="performance-range-time-zone">
    <span><%= t ".time_zone" %></span>
    <span data-performance-range-target="timeZoneLabel"><%= time_zone_label %></span>
    <% if local_assigns[:bucket_size] %>
      <span class="mx-1" aria-hidden="true">·</span>
      <span class="performance-chart-bucket-size"><%= t ".chart_bucket_size", size: bucket_size %></span>
    <% end %>
  </div>
<% end %>

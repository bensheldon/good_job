  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/generator/generator.rb:74
  def generate_entry_between_tags(older_tag, newer_tag); end

  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/generator/generator.rb:130
  def generate_unreleased_entry; end

  # Add template messages to given string. Previously added
  # messages of the same wording are removed.
  #
  # @param log [String]
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/generator/generator.rb:173
  def insert_fixed_string(log); end

  # Remove the previously assigned fixed message.
  #
  # @param log [String] Old lines are fixed
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/generator/generator.rb:163
  def remove_old_fixed_string(log); end

  # Detect if a sha occurs in the --release-branch. Uses the github repo
  # default branch if not specified.
  #
  # @param sha [String] SHA to check.
  # @return [Boolean] True if SHA is in the branch git history.
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/generator/generator_fetcher.rb:196
  def sha_in_release_branch?(sha); end

  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/generator/generator_tags.rb:197
  def warn_if_nonmatching_regex(all_tags, regex, regex_option_name); end

  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/generator/generator_tags.rb:204
  def warn_if_tag_not_found(all_tags, tag); end
end


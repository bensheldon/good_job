  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/generator/section.rb:74
  def issue_line_with_body(line, issue); end

  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/generator/section.rb:97
  def issue_line_with_user(line, issue); end

  # Normalize line endings from CRLF to LF
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/generator/section.rb:89
  def normalize_body(body); end

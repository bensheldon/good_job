  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/options.rb:111
  def print_options; end

  # @return [Hash]
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/options.rb:101
  def to_hash; end

  # @return [Boolean] whether write to `:output`
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/options.rb:134
  def write_to_file?; end

  private

  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/options.rb:151
  def censored_token(opts_token); end

  # Returns a censored options hash.
  #
  # @return [Hash] The GitHub `:token` key is censored in the output.

# A Fetcher responsible for all requests to GitHub and all basic manipulation with related data
# (such as filtering, validating, e.t.c)
#
# Example:
# fetcher = GitHubChangelogGenerator::OctoFetcher.new(options)
#
# pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:15
class GitHubChangelogGenerator::OctoFetcher
  # @option options
  # @option options
  # @option options
  # @option options
  # @option options
  # @option options
  # @param options [Hash] Options passed in
  # @return [OctoFetcher] a new instance of OctoFetcher
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:32
  def initialize(options = T.unsafe(nil)); end

  # Returns the number of pages for a API call
  #
  # @param client [Object]
  # @param method [Object]
  # @param request_options [Object]
  # @return [Integer] number of pages for this API call in total
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:114
  def calculate_pages(client, method, request_options); end

  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:88
  def client; end

  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:71
  def client_options; end

  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:154
  def closed_pr_options; end

  # Fetch all commits
  #
  # @return [Array] Commits in a repo.
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:307
  def commits; end

  # @param name [String]
  # @return [Array<String>]
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:348
  def commits_in_branch(name); end

  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:65
  def connection_options; end

  # @return [String] Default branch of the repo
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:342
  def default_branch; end

  # Fetch all tags from repo
  #
  # @return [Array <Hash>] array of tags
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:97
  def fetch_all_tags; end

  # This method fetch all closed issues and separate them to pull requests and pure issues
  # (pull request is kind of issue in term of GitHub)
  #
  # @return [Tuple] with (issues [Array <Hash>], pull-requests [Array <Hash>])
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:164
  def fetch_closed_issues_and_pr; end

  # Fetch all pull requests. We need them to detect :merged_at parameter
  #
  # @return [Array <Hash>] all pull requests
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:187
  def fetch_closed_pull_requests; end

  # Fetch comments for PRs and add them to "comments"
  #
  # @param prs [Array] The array of PRs.
  # @return [Void] No return; PRs are updated in-place.
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:247
  def fetch_comments_async(prs); end

  # Fetch commit for specified event
  #
  # @param commit_id [String] the SHA of a commit to fetch
  # @return [Hash]
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:286
  def fetch_commit(commit_id); end

  # Fetch tag time from repo
  #
  # @param tag [Hash] GitHub data item about a Tag
  # @return [Time] time of specified tag
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:275
  def fetch_date_of_tag(tag); end

  # Fetch event for all issues and add them to 'events'
  #
  # @param issues [Array]
  # @return [Void]
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:210
  def fetch_events_async(issues); end

  # Fetch all SHAs occurring in or before a given tag and add them to
  # "shas_in_tag"
  #
  # @param tags [Array] The array of tags.
  # @return void
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:369
  def fetch_tag_shas(tags); end

  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:103
  def get_all_tags; end

  # Fill input array with tags
  #
  # @return [Array <Hash>] array of tags in repo
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:132
  def github_fetch_tags; end

  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:45
  def middleware; end

  # Return the oldest commit in a repo
  #
  # @return [Hash] Oldest commit in the github git history.
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:337
  def oldest_commit; end

  private

  # This is wrapper with rescue block
  #
  # @param block [Proc]
  # @return [Object] returns exactly the same, what you put in the block, but wrap it with begin-rescue block
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:476
  def check_github_response; end

  # @param sha [Object]
  # @param shas [Set]
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:380
  def commits_in_tag(sha, shas = T.unsafe(nil)); end

  # Presents the exception, and the aborts with the message.
  #
  # @param error [Object]
  # @param message [Object]
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:500
  def fail_with_message(error, message); end

  # Returns GitHub token. First try to use variable, provided by --token option,
  # otherwise try to fetch it from CHANGELOG_GITHUB_TOKEN env variable.
  #
  # @return [String]
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:526
  def fetch_github_token; end

  # Iterates through all pages until there are no more :next pages to follow
  # yields the result per page
  #
  # @param arguments [Array]
  # @param client [Octokit::Client]
  # @param method [String] (eg. 'tags')
  # @param options [Hash]
  # @param parent [Async::Semaphore]
  # @return [void]
  # @yield [Sawyer::Resource] An OctoKit-provided response (which can be empty)
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:442
  def iterate_pages(client, method, *arguments, parent: T.unsafe(nil), **options); end

  # Print long line with spaces on same line to clear prev message
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:518
  def print_empty_line; end

  # Print specified line on the same string
  #
  # @param log_string [String]
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:513
  def print_in_same_line(log_string); end

  # Returns Hash of all querystring variables in given URI.
  #
  # @param uri [String] eg. https://api.github.com/repositories/43914960/tags?page=37&foo=1
  # @return [Hash] of all GET variables. eg. { 'page' => 37, 'foo' => 1 }
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:543
  def querystring_as_hash(uri); end

  # @param indata [Object]
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:412
  def stringify_keys_deep(indata); end

  # @param msg [Object]
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:506
  def sys_abort(msg); end

  # @return [String] helper to return GitHub "user/project"
  #
  # pkg:gem/github_changelog_generator#lib/github_changelog_generator/octo_fetcher.rb:535
  def user_project; end
end

